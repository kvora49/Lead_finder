rules_version = '2';
// ─────────────────────────────────────────────────────────────────────────────
// Lead Finder — Firestore Security Rules  (Phase 1)
//
// Principle of Least Privilege:
//   • Every collection is DENY-ALL by default.
//   • Users can only read/write their OWN data.
//   • Admin privileges are read from the user's Firestore document (role field),
//     which is written server-side on registration and never exposed client-side.
//   • The public_search_cache is readable by all authenticated users so we can
//     serve zero-cost cached results without hitting the Google Places API again.
// ─────────────────────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserRole() in ['admin', 'super_admin', 'owner'];
    }

    function isSuperAdmin() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserRole() in ['super_admin', 'owner'];
    }

    function isOwnerRole() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserRole() == 'owner';
    }

    // ── Role-change guard helpers ────────────────────────────────────────────
    // True iff the 'role' field is being changed in this write
    function roleChanging() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    // True iff the target document's CURRENT role is owner or super_admin
    // (ghost-owner protection: super_admin cannot touch these rows)
    function targetIsPrivileged() {
      return resource.data.role in ['owner', 'super_admin'];
    }

    // The new role value the client is trying to set
    function newRole() {
      return request.resource.data.role;
    }

    // super_admin may only set role to 'user' or 'admin' — never back to
    // 'super_admin' or 'owner', and only on rows that are not already privileged.
    function superAdminRoleChangeAllowed() {
      return isSuperAdmin()
        && !isOwnerRole()
        && !targetIsPrivileged()
        && newRole() in ['user', 'admin'];
    }

    // Owner may change any role (including to/from super_admin)
    // EXCEPT their own row — prevents accidental self-demotion.
    // userId must be passed in because path variables are not in scope
    // inside helper functions.
    function ownerRoleChangeAllowed(uid) {
      return isOwnerRole() && request.auth.uid != uid;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // DENY-ALL FALLBACK  (Principle of Least Privilege)
    // ═══════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // USER PROFILES   users/{userId}

      // ═══════════════════════════════════════════════════════════════════════
      // USER PROFILES   users/{userId}
      // ═══════════════════════════════════════════════════════════════════════
    // ═══════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Users read their own profile; admins read all
      allow read: if isOwner(userId) || isAdmin();

      // Registration: owner may create ONLY with safe defaults
      // This prevents a malicious client from self-promoting to admin
      allow create: if isOwner(userId)
        && request.resource.data.uid        == userId
        && request.resource.data.role       == 'user'
        && request.resource.data.credits    == 100
        && request.resource.data.isActive   == true;

      // Users update their own profile except sensitive fields.
      // 'credits' (balance) and 'role' are server/admin-controlled.
      // 'creditsUsed' and 'searchCount' are owner-writable (Phase 3 batched writes).
      //
      // Role-change rules (enforced at DB level, matches UI RBAC):
      //   admin       → cannot change 'role' field at all
      //   super_admin → can change 'role' to 'user' or 'admin' only,
      //                 and ONLY on rows that are not 'owner'/'super_admin'
      //   owner       → can change 'role' to any value
      allow update: if (
          // Self-update: own non-sensitive fields only
          (isOwner(userId)
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['role', 'isActive', 'uid', 'createdAt']))
          // Admin (all tiers): can update non-role fields (status, creditLimit, etc.)
          || (isAdmin() && !roleChanging()
              && !request.resource.data.diff(resource.data).affectedKeys()
                  .hasAny(['uid', 'createdAt']))
          // super_admin: role change under strict conditions (see helper)
          || (roleChanging() && superAdminRoleChangeAllowed())
          // owner: role change unrestricted except own row
          || (roleChanging() && ownerRoleChangeAllowed(userId))
        );

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // PUBLIC SEARCH CACHE   public_search_cache/{cacheId}
    // Zero-cost layer: serve identical queries from Firestore, not Google API
    // ═══════════════════════════════════════════════════════════════════════
    match /public_search_cache/{cacheId} {
      allow read: if isAuth();

      allow create, update: if isAuth()
        && request.resource.data.keys().hasAll(['query', 'location', 'results', 'cachedAt']);

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OTP CODES   otp_codes/{email}
    // Temporary short-lived documents written by AdminGatekeeper during the
    // email verification flow. Auto-deleted after successful verify.
    //   WRITE  — any authenticated user may write their own OTP doc
    //            (doc ID = their email address).
    //   READ   — only the owner of that email address.
    //   DELETE — only the owner (cleanup after verify).
    // ═══════════════════════════════════════════════════════════════════════
    match /otp_codes/{email} {
      allow read, delete: if isAuth() && request.auth.token.email == email;
      allow write:        if isAuth() && request.auth.token.email == email;
    }

    // ═══════════════════════════════════════════════════════════════════    // GLOBAL API COST TRACKER   system/global_usage
    // Phase 3: Single document tracking aggregate Google Places API spend.
    //
    //   READ  — any authenticated user (shows budget banner in UI).
    //   WRITE — authenticated users may only touch the four safe fields that
    //           the deductCredits transaction writes. This prevents a client
    //           from overwriting the monthly_api_cost to 0 to bypass the cap.
    //           Full resets and other system docs remain admin-only.
    // ═══════════════════════════════════════════════════════════════════
    match /system/{docId} {
      allow read: if isAuth();

      // Any authenticated user may create or update global_usage.
      // The deductCredits transaction writes month, monthly_api_cost,
      // totalApiCalls, and lastUpdated. A full set() is used for month
      // resets, so we allow that too. Only the four safe fields may appear
      // in documents written by clients; admins may write anything.
      allow create: if isAuth()
        && request.resource.data.keys().hasOnly(
             ['month', 'monthly_api_cost', 'totalApiCalls', 'lastUpdated']
           );

      allow update: if isAuth()
        && (
          request.resource.data.keys().hasOnly(
            ['month', 'monthly_api_cost', 'totalApiCalls', 'lastUpdated']
          )
          || isAdmin()
        );

      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // USER CREDIT LOGS (sub-collection)   users/{userId}/credit_logs/{logId}
    // Phase 3: Append-only audit trail written by the deductCredits transaction.
    // Users can read their own receipts; only admins can delete.
    // ═══════════════════════════════════════════════════════════════════════
    match /users/{userId}/credit_logs/{logId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.userId == userId
        && request.resource.data.keys().hasAll(['userId', 'apiCalls', 'costUsd', 'month', 'createdAt']);
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════    // USER SEARCHES (sub-collection)  users/{userId}/searches/{id}
    // ═══════════════════════════════════════════════════════════════════════
    match /users/{userId}/searches/{searchId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // USER LISTS (sub-collection)   users/{userId}/lists/{listId}
    // ═══════════════════════════════════════════════════════════════════════
    match /users/{userId}/lists/{listId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /leads/{leadId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CREDIT TRANSACTIONS   credit_transactions/{txId}
    // Append-only for users to prevent tampering
    // ═══════════════════════════════════════════════════════════════════════
    match /credit_transactions/{txId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CREDIT REQUESTS   credit_requests/{requestId}
    // Users can create/read their own top-up requests.
    // Admins can read/update/delete all requests.
    // ═══════════════════════════════════════════════════════════════════════
    match /credit_requests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SEARCH LOGS   searchLogs/{logId}
    // ═══════════════════════════════════════════════════════════════════════
    match /searchLogs/{logId} {
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SYSTEM LOGS (camelCase)   systemLogs/{logId}
    // analyticsService.js writes here; admin dashboard reads here
    // ═══════════════════════════════════════════════════════════════════════
    match /systemLogs/{logId} {
      allow read:           if isAdmin();
      allow create:         if isAuth();
      allow update, delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // ADMIN-ONLY COLLECTIONS
    // ═══════════════════════════════════════════════════════════════════════
    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }

    match /monthlyAnalytics/{monthId} {
      allow read, write: if isAdmin();
    }

    // Global runtime settings required by authenticated clients (e.g. maintenance mode).
    // Keep writes admin-only, but allow signed-in users to read this single document.
    match /systemConfig/globalSettings {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /systemConfig/{configId} {
      allow read, write: if isAdmin();
    }

    // adminUsers: admins can read the registry; only super_admins can modify
    match /adminUsers/{email} {
      allow read:  if isAdmin();
      allow write: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // ADMIN INVITES   admin_invites/{token}
    // Written and read exclusively by Cloud Functions via the Admin SDK.
    // The Admin SDK bypasses all client-side security rules, so there is no
    // need to grant any client access — deny everything.
    // ═══════════════════════════════════════════════════════════════════════
    match /admin_invites/{token} {

          // ═══════════════════════════════════════════════════════════════════════
          // DENY-ALL FALLBACK  (Principle of Least Privilege)
          // MUST BE LAST so specific collection rules are evaluated first!
          // ═══════════════════════════════════════════════════════════════════════
          match /{document=**} {
            allow read, write: if false;
          }
      allow read, write: if false;
    }
  }
}
